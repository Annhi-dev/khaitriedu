        $user = $sessionUser();
        $cert = App\Models\Certificate::with('course')->find($id);
        if (!$user || !$cert || $cert->user_id !== $user->id) {
            return redirect()->route('certificates.index')->with('error', 'Chứng chỉ không tồn tại.');
        }
        return view('certificates.show', compact('cert', 'user'));
