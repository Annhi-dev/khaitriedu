});
Route::prefix('student')->name('student.')->group(function () use ($sessionUser, $requireRole) {
    Route::get('/schedule', function () use ($sessionUser, $requireRole) {
        if ($redirect = $requireRole($user = $sessionUser(), 'hoc_vien')) return $redirect;
        $enrollments = App\Models\Enrollment::where('user_id', $user->id)
            ->where('status', 'confirmed')
            ->whereNotNull('course_id')
            ->with(['course.subject', 'assignedTeacher'])
            ->orderByDesc('id')
            ->get();
        return view('student.schedule', compact('user', 'enrollments'));
    })->name('schedule');
    Route::get('/grades', function () use ($sessionUser, $requireRole) {
        if ($redirect = $requireRole($user = $sessionUser(), 'hoc_vien')) return $redirect;
        $grades = App\Models\Grade::whereHas('enrollment', function ($query) use ($user) {
            $query->where('user_id', $user->id);
        })->with(['enrollment.course.subject', 'module'])->get();
        return view('student.grades', compact('user', 'grades'));
    })->name('grades');
});
Route::prefix('teacher')->name('teacher.')->group(function () use ($sessionUser, $requireRole) {
    Route::get('/', function () use ($sessionUser, $requireRole) {
        if ($redirect = $requireRole($user = $sessionUser(), 'giang_vien')) return $redirect;
        return redirect()->route('teacher.courses');
    })->name('dashboard');
    Route::get('/courses', function () use ($sessionUser, $requireRole) {
        if ($redirect = $requireRole($user = $sessionUser(), 'giang_vien')) return $redirect;
        $courses = App\Models\Course::where('teacher_id', $user->id)
            ->with(['subject.category', 'modules'])
            ->withCount('enrollments')
            ->get();
        $enrollments = App\Models\Enrollment::whereIn('course_id', $courses->pluck('id'))
            ->with(['user', 'course.subject'])
            ->orderByDesc('id')
            ->get();
        return view('teacher.courses', compact('user', 'courses', 'enrollments'));
    })->name('courses');
    Route::get('/courses/{id}', function ($id) use ($sessionUser, $requireRole) {
        if ($redirect = $requireRole($user = $sessionUser(), 'giang_vien')) return $redirect;
        $course = App\Models\Course::where('teacher_id', $user->id)
            ->with(['subject.category', 'modules', 'enrollments.user'])
            ->find($id);
        if (!$course) {
            return redirect()->route('teacher.courses')->with('error', 'Lớp học không tồn tại.');
        }
        $gradeMap = App\Models\Grade::whereIn('enrollment_id', $course->enrollments->pluck('id'))
            ->get()
            ->keyBy(function ($grade) {
                return $grade->enrollment_id . '-' . ($grade->module_id ?? 'summary');
            });
        return view('teacher.course_show', compact('course', 'user', 'gradeMap'));
    })->name('course.show');
    Route::post('/grades', function (Request $request) use ($sessionUser, $requireRole) {
        if ($redirect = $requireRole($user = $sessionUser(), 'giang_vien')) return $redirect;
        $data = $request->validate([
            'enrollment_id' => 'required|exists:dang_ky,id',
            'module_id' => 'nullable|exists:chuong_hoc,id',
            'score' => 'nullable|numeric|min:0|max:100',
            'grade' => 'nullable|string|max:5',
            'feedback' => 'nullable|string|max:1000',
        ]);
        $enrollment = App\Models\Enrollment::with('course')->find($data['enrollment_id']);
        if (!$enrollment || !$enrollment->course || $enrollment->course->teacher_id !== $user->id) {
            return back()->with('error', 'Bạn không có quyền nhập điểm cho lớp học này.');
        }
        App\Models\Grade::updateOrCreate(
            ['enrollment_id' => $data['enrollment_id'], 'module_id' => $data['module_id']],
            array_filter($data, fn ($value) => $value !== null)
        );
        return back()->with('status', 'Điểm đã được cập nhật.');
    })->name('grades.update');
});
